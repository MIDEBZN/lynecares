---
import Layout from '../layouts/Layout.astro';

const locations = [
  "Liège Centre", "Seraing", "Herstal", "Ans", "Saint-Nicolas", 
  "Flémalle", "Oupeye", "Grâce-Hollogne", "Chaudfontaine", "Visé"
];
---

<Layout 
	title="Zones d'Intervention Plombier Liège | LYNECARES" 
	description="LYNECARES intervient rapidement dans toute la province de Liège. Découvrez nos zones d'intervention pour vos dépannages en plomberie et chauffage."
>
	<div class="page-header">
		<div class="container text-center">
			<h1>Zones d'Intervention</h1>
			<p class="page-subtitle">Nous couvrons l'ensemble de la région liégeoise pour des interventions rapides.</p>
		</div>
	</div>

	<div class="container py-5">
		<div class="content-wrapper">
			<div class="map-section">
				<div class="map-placeholder">
					<div class="map-overlay">
						<h3>Intervention rapide dans un rayon de 30km autour de Liège</h3>
					</div>
				</div>
			</div>
			
			<div class="locations-content">
				<h2>Toujours près de chez vous</h2>
				<p class="mb-2">Notre position centrale à Liège nous permet d'intervenir extrêmement rapidement dans toute l'agglomération et les communes avoisinantes. En cas d'urgence, nous garantissons une intervention dans les plus brefs délais.</p>
				
				<div class="locations-grid">
					{locations.map(loc => (
						<div class="location-item">
							<span class="loc-icon">📍</span>
							<span class="loc-name">{loc}</span>
						</div>
					))}
				</div>
				
				<div class="info-box mt-3">
					<h4>Votre commune n'est pas dans la liste ?</h4>
					<p>Contactez-nous pour vérifier notre disponibilité dans votre région. Nous nous déplaçons au-delà de ces communes selon la nature de l'intervention.</p>
					<a href="/contact" class="btn btn-outline mt-1">Nous contacter</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background: var(--primary);
		color: white;
		padding: 6rem 0 4rem;
		margin-bottom: 4rem;
	}

	.page-header h1 {
		color: white;
		margin-bottom: 1rem;
	}

	.page-subtitle {
		color: #94a3b8;
		font-size: 1.2rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.py-5 {
		padding-top: 2rem;
		padding-bottom: 5rem;
	}

	.content-wrapper {
		display: flex;
		gap: 4rem;
		align-items: flex-start;
	}

	.map-section {
		flex: 1;
		position: sticky;
		top: 100px;
	}

	.map-placeholder {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 20px;
		background: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80') center/cover;
		position: relative;
		overflow: hidden;
		box-shadow: 0 20px 40px rgba(0,0,0,0.1);
	}

	.map-overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: rgba(15, 23, 42, 0.9);
		backdrop-filter: blur(5px);
		padding: 1.5rem;
		color: white;
		text-align: center;
	}

	.map-overlay h3 {
		color: white;
		font-size: 1.2rem;
		margin: 0;
	}

	.locations-content {
		flex: 1;
	}

	.locations-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
		gap: 1rem;
	}

	.location-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem;
		background: var(--bg-alt);
		border-radius: var(--radius);
		border: 1px solid rgba(0,0,0,0.05);
		transition: transform 0.2s;
	}

	.location-item:hover {
		transform: translateY(-2px);
		border-color: var(--secondary);
	}

	.loc-icon {
		color: var(--secondary);
	}

	.loc-name {
		font-weight: 500;
	}

	.info-box {
		background: rgba(14, 165, 233, 0.05);
		border-left: 4px solid var(--secondary);
		padding: 2rem;
		border-radius: 0 var(--radius) var(--radius) 0;
	}

	.info-box h4 {
		color: var(--primary);
		margin-bottom: 0.5rem;
	}

	.mt-1 { margin-top: 1rem; }
	.mt-3 { margin-top: 3rem; }
	.mb-2 { margin-bottom: 2rem; }

	@media (max-width: 992px) {
		.content-wrapper {
			flex-direction: column;
		}
		.map-section {
			position: static;
			width: 100%;
		}
		.map-placeholder {
			aspect-ratio: 21/9;
		}
	}
</style>

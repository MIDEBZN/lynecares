---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Contact & Devis | LYNECARES Plombier Liège" 
	description="Contactez LYNECARES pour un dépannage urgent ou une demande de devis. Plombier chauffagiste disponible 24/7 à Liège. Devis gratuit."
>
	<div class="page-header">
		<div class="container text-center">
			<h1>Contactez-Nous</h1>
			<p class="page-subtitle">Une urgence ? Un projet ? Nous sommes à votre écoute 24h/24 et 7j/7.</p>
		</div>
	</div>

	<div class="container py-5">
		<div class="contact-grid">
			<!-- Contact Info -->
			<div class="contact-info">
				<h2>Nos Coordonnées</h2>
				<p class="mb-3">Notre équipe de techniciens est prête à intervenir. Pour toute urgence, privilégiez le contact téléphonique pour une intervention immédiate.</p>

				<div class="info-card">
					<div class="info-icon">📞</div>
					<div>
						<h3>Téléphone (Urgences 24/7)</h3>
						<a href="tel:+3240000000" class="info-link">+32 4 000 00 00</a>
					</div>
				</div>

				<div class="info-card">
					<div class="info-icon">✉️</div>
					<div>
						<h3>Email</h3>
						<a href="mailto:contact@lynecares.be" class="info-link">contact@lynecares.be</a>
					</div>
				</div>

				<div class="info-card">
					<div class="info-icon">📍</div>
					<div>
						<h3>Adresse (Bureau administratif)</h3>
						<p>Rue de la Plomberie 123<br>4000 Liège, Belgique</p>
					</div>
				</div>
				
				<div class="hours-card mt-3">
					<h3>Heures d'ouverture</h3>
					<ul>
						<li><strong>Lundi - Vendredi:</strong> 8h00 - 18h00</li>
						<li><strong>Samedi - Dimanche:</strong> Sur rendez-vous</li>
						<li class="urgence-text"><strong>Urgences Dépannage:</strong> 24h/24 - 7j/7</li>
					</ul>
				</div>
			</div>

			<!-- Contact Form -->
			<div class="contact-form-wrapper">
				<h2>Demander un Devis Gratuit</h2>
				<p class="mb-2">Remplissez ce formulaire et nous vous recontacterons dans les plus brefs délais.</p>
				
				<form class="contact-form" onsubmit="event.preventDefault(); alert('Merci pour votre message. Nous vous contacterons bientôt.');">
					<div class="form-group">
						<label for="name">Nom Complet *</label>
						<input type="text" id="name" name="name" required placeholder="Votre nom" />
					</div>
					
					<div class="form-row">
						<div class="form-group">
							<label for="phone">Téléphone *</label>
							<input type="tel" id="phone" name="phone" required placeholder="Ex: 04 123 45 67" />
						</div>
						<div class="form-group">
							<label for="email">Email *</label>
							<input type="email" id="email" name="email" required placeholder="votre@email.com" />
						</div>
					</div>
					
					<div class="form-group">
						<label for="service">Service concerné</label>
						<select id="service" name="service">
							<option value="depannage">Dépannage Urgent</option>
							<option value="installation">Installation Sanitaire</option>
							<option value="chauffage">Entretien/Réparation Chauffage</option>
							<option value="autre">Autre demande</option>
						</select>
					</div>
					
					<div class="form-group">
						<label for="message">Votre Message *</label>
						<textarea id="message" name="message" rows="5" required placeholder="Décrivez votre problème ou votre projet..."></textarea>
					</div>
					
					<button type="submit" class="btn btn-primary w-100">Envoyer la Demande</button>
				</form>
			</div>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background: var(--primary);
		color: white;
		padding: 6rem 0 4rem;
		margin-bottom: 4rem;
	}

	.page-header h1 {
		color: white;
		margin-bottom: 1rem;
	}

	.page-subtitle {
		color: #94a3b8;
		font-size: 1.2rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.py-5 {
		padding-top: 2rem;
		padding-bottom: 5rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
	}

	.contact-info h2, .contact-form-wrapper h2 {
		color: var(--primary);
		margin-bottom: 1rem;
	}

	.info-card {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background: var(--bg-alt);
		border-radius: var(--radius);
		border: 1px solid rgba(0,0,0,0.05);
	}

	.info-icon {
		font-size: 2rem;
		background: white;
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		box-shadow: 0 5px 15px rgba(0,0,0,0.05);
	}

	.info-card h3 {
		font-size: 1.1rem;
		margin-bottom: 0.3rem;
	}

	.info-link {
		color: var(--secondary);
		font-weight: 600;
		font-size: 1.1rem;
	}

	.info-link:hover {
		color: var(--primary);
	}

	.hours-card {
		background: var(--primary);
		color: white;
		padding: 2rem;
		border-radius: var(--radius);
	}

	.hours-card h3 {
		color: white;
		margin-bottom: 1rem;
	}

	.hours-card ul {
		list-style: none;
	}

	.hours-card li {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.8rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}

	.hours-card li:last-child {
		border-bottom: none;
		margin-bottom: 0;
		padding-bottom: 0;
	}

	.urgence-text {
		color: var(--accent);
	}

	/* Form Styles */
	.contact-form-wrapper {
		background: white;
		padding: 3rem;
		border-radius: 24px;
		box-shadow: 0 20px 40px rgba(0,0,0,0.08);
		border: 1px solid rgba(0,0,0,0.05);
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.form-group label {
		font-weight: 600;
		color: var(--text-dark);
		font-size: 0.95rem;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: 1rem;
		border: 1px solid #cbd5e1;
		border-radius: 8px;
		font-family: inherit;
		font-size: 1rem;
		transition: all 0.3s;
		background: var(--bg-alt);
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--secondary);
		background: white;
		box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
	}

	.w-100 {
		width: 100%;
		padding: 1.2rem;
		font-size: 1.1rem;
	}

	.mt-3 { margin-top: 3rem; }
	.mb-2 { margin-bottom: 2rem; }
	.mb-3 { margin-bottom: 3rem; }

	@media (max-width: 992px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
		.form-row {
			grid-template-columns: 1fr;
		}
		.contact-form-wrapper {
			padding: 2rem;
		}
	}
</style>
